{
  "name": "@fly4react/i18n-server",
  "version": "0.0.0",
  "description": "Server-side and RSC APIs for @fly4react/i18n",
  "license": "MIT",
  "author": "Jacob Zong",
  "type": "module",
  "main": "./dist/index.js",
