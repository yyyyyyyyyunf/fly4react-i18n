    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fly4react/i18n-cli": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
