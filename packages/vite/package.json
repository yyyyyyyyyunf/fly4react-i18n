{
  "name": "@fly4react/i18n-vite",
  "version": "0.0.0",
  "description": "Vite plugin for @fly4react/i18n",
  "license": "MIT",
  "author": "Jacob Zong",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
