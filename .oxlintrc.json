{
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "rules": {
    "no-console": "warn",
    "no-debugger": "error"
  },
  "overrides": [
    {
      "files": ["packages/cli/src/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["packages/core/src/persist.ts"],
      "rules": {
        "unicorn/no-document-cookie": "off"
      }
    }
  ]
}
